{
  "name": "@mnem/storage-s3",
  "version": "0.1.0",
  "description": "S3-compatible object storage adapter for Mnem.",
  "keywords": [
    "mnem",
    "storage",
    "s3",
    "aws",
    "llm-memory"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/artik0din/mnem.git",
    "directory": "packages/storage-s3"
  },
  "bugs": "https://github.com/artik0din/mnem/issues",
  "homepage": "https://github.com/artik0din/mnem#readme",
  "author": "Kevin Valfin",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "@mnem/core": "workspace:*",
    "@aws-sdk/client-s3": "^3.721.0"
  },
  "devDependencies": {
    "aws-sdk-client-mock": "^4.1.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
