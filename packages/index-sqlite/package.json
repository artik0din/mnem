{
  "name": "@mnem/index-sqlite",
  "version": "0.1.0",
  "description": "Embedded SQLite index adapter for Mnem with full-text and vector search.",
  "keywords": [
    "mnem",
    "index",
    "sqlite",
    "fts5",
    "vector-search",
    "llm-memory"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/artik0din/mnem.git",
    "directory": "packages/index-sqlite"
  },
  "bugs": "https://github.com/artik0din/mnem/issues",
  "homepage": "https://github.com/artik0din/mnem#readme",
  "author": "Kevin Valfin",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "@mnem/core": "workspace:*",
    "better-sqlite3": "^11.7.0"
  },
  "peerDependencies": {
    "sqlite-vec": "^0.1.0"
  },
  "peerDependenciesMeta": {
    "sqlite-vec": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
