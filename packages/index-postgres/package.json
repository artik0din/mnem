{
  "name": "@mnem/index-postgres",
  "version": "0.0.0",
  "description": "PostgreSQL index adapter for Mnem with pgvector semantic search.",
  "keywords": [
    "mnem",
    "index",
    "postgres",
    "pgvector",
    "vector-search",
    "llm-memory"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/artik0din/mnem.git",
    "directory": "packages/index-postgres"
  },
  "bugs": "https://github.com/artik0din/mnem/issues",
  "homepage": "https://github.com/artik0din/mnem#readme",
  "author": "Kevin Valfin",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "@mnem/core": "workspace:*",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
